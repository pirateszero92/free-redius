server inner-tunnel {

listen {
       ipaddr = 127.0.0.1
       port = 18120
       type = auth
}

authorize {
    filter_username
    chap
    mschap
    suffix
    update control {
           &Proxy-To-Realm := LOCAL
    }
    eap {
        ok = return
    }
    files
    sql
    ldap
    if ((ok || updated) && User-Password && !control:Auth-Type) {
        update {
            control:Auth-Type := ldap
        }
    }
    expiration
    logintime
    pap
}

authenticate {
    Auth-Type PAP {
        pap
    }
    Auth-Type CHAP {
        chap
    }
    Auth-Type MS-CHAP {
        mschap
    }
    Auth-Type LDAP {
        ldap
    }
    eap
}

session {
    sql
}

post-auth {
    sql
    Post-Auth-Type REJECT {
        sql
        attr_filter.access_reject
    }
}

pre-proxy {
}

post-proxy {
    eap
}

}

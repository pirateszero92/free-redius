# PostgreSQL
POSTGRES_DB=radius
POSTGRES_USER=radius
POSTGRES_PASSWORD=radius_secret_change_me

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=24h

# Web Port
WEB_PORT=80

# Initial Admin Account (used only on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
